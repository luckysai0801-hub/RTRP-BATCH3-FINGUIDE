{
  "name": "finguide-backend",
  "version": "2.0.0",
  "description": "FIN GUIDE – Smart Financial Product Comparison Platform (PostgreSQL + Sequelize)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed": "node -r dotenv/config scripts/seed.js",
    "db:sync": "node -r dotenv/config -e \"require('./models').sequelize.sync({force:true}).then(()=>{console.log('DB synced');process.exit(0)})\""
  },
  "dependencies": {
    "@google/generative-ai": "^0.2.1",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.20.0",
    "node-cron": "^3.0.3",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "playwright": "^1.59.1",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
